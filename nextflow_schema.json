{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BioimageAnalysisCoreWEHI/export_qupath_measurements/main/nextflow_schema.json",
  "title": "export_qupath_measurements pipeline parameters",
  "description": "Headless QuPath measurement export from a QuPath project",
  "type": "object",
  "$defs": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "required": ["project", "qupath_bin", "outdir"],
      "properties": {
        "project": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "description": "Path to QuPath project .qpproj file"
        },
        "qupath_bin": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "description": "Path to QuPath executable, e.g. /vast/projects/SOLACE2/QuPath/bin/QuPath"
        },
        "script": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "default": "bin/export_image_measurements_indiv.groovy",
          "description": "Path to Groovy script run by QuPath in headless mode"
        },
        "outdir": {
          "type": "string",
          "format": "directory-path",
          "description": "Output directory for exported measurements"
        },
        "publish_dir_mode": {
          "type": "string",
          "default": "copy",
          "description": "Method used by Nextflow publishDir",
          "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"]
        }
      }
    },
    "generic_options": {
      "title": "Generic options",
      "type": "object",
      "properties": {
        "validate_params": {
          "type": "boolean",
          "default": true,
          "hidden": true,
          "description": "Validate parameters against schema"
        }
      }
    }
  },
  "allOf": [
    { "$ref": "#/$defs/input_output_options" },
    { "$ref": "#/$defs/generic_options" }
  ]
}
